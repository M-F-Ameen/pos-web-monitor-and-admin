{
  "name": "freedom-pos",
  "private": true,
  "version": "1.0.0",
  "description": "Freedom POS Desktop Application",
  "author": "Freedom",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -k -n VITE,ELECTRON \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "preview": "vite preview",
    "catalog:seed:egypt": "electron scripts/reset-egypt-catalog.mjs",
    "seed:test": "electron scripts/seed-test-data.mjs",
    "test": "electron scripts/test-all.mjs",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "postinstall": "electron-rebuild"
  },
  "build": {
    "appId": "com.freedom.pos",
    "productName": "Freedom",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "public/eagle.png",
        "to": "eagle.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/eagle.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsbarcode": "^3.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
}

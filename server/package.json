{
  "name": "pos-cloud-server",
  "version": "1.0.0",
  "private": true,
  "description": "Cloud API & real-time sync server for Freedom POS monitoring",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/db/schema.sql dist/db/schema.sql && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "socket.io": "^4.8.0",
    "pg": "^8.13.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "uuid": "^10.0.0",
    "helmet": "^8.0.0",
    "compression": "^1.7.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@types/compression": "^1.7.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
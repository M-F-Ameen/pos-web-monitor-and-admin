# ──────────────────────────────────────────────
# pos-cloud-server — Environment Variables
# Multi-Tenant Configuration
# ──────────────────────────────────────────────

# ──────────────────────────────────────────────
# Railway Deployment
# ──────────────────────────────────────────────
# PostgreSQL URL is auto-set by Railway when you attach the PostgreSQL plugin.
# PORT is auto-set by Railway (default 4000).
# NODE_ENV should be set to "production" in Railway.
#
# REQUIRED (set in Railway dashboard):
#   JWT_SECRET=<strong-random-string-at-least-32-chars>
#
# IMPORTANT: After first deploy, you must create at least one tenant
# via the admin panel to get api_key and monitor_key for your POS terminals.
# ──────────────────────────────────────────────

# PostgreSQL (auto-set by Railway in production)
DATABASE_URL=postgresql://user:password@localhost:5432/pos_monitor

# Server
PORT=4000
NODE_ENV=development

# REQUIRED in production: JWT signing secret (min 32 chars)
# JWT_SECRET=change-me-to-a-strong-random-secret

# ──────────────────────────────────────────────
# Multi-Tenant Authentication
#
# Each POS terminal gets a unique api_key, each monitor gets a unique monitor_key.
# Keys are generated and managed via the admin panel's tenant creation API.
#
# SYNC_SECRET (optional, backward compatibility):
#   During migration from single-tenant, you can set this to a shared secret.
#   The server will map it to the first tenant in the database.
#   Remove once all POS installations have been migrated to per-tenant api_keys.
# ──────────────────────────────────────────────

# SYNC_SECRET=your-legacy-shared-secret

# CORS origins (comma-separated)
# In production, add your frontend's Railway URL:
# ALLOWED_ORIGINS=https://your-frontend.up.railway.app
# The server also respects the RAILWAY_FRONTEND_URL env var automatically.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────────────────────
# Provisioning a new tenant (first-time setup):
#
# After deployment, call the admin API:
#   POST /api/admin/tenants
#   Headers: Authorization: Bearer <admin_jwt>
#   Body: { name, slug, adminEmail, adminPassword, adminName }
#
# This creates the tenant and returns api_key + monitor_key.
# Use these keys to configure your POS desktop app:
#
#   POS desktop .env:
#     CLOUD_SYNC_URL=https://your-server.up.railway.app
#     CLOUD_SYNC_SECRET=<api_key>
#
#   Monitor web app Railway env vars:
#     NEXT_PUBLIC_CLOUD_API_URL=https://your-server.up.railway.app/api
# ──────────────────────────────────────────────

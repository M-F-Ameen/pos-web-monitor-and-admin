# ──────────────────────────────────────────────
# POS Monitor Dashboard — Environment Variables
# ──────────────────────────────────────────────

# REQUIRED: URL of the Cloud API server (Express backend)
# In development: http://localhost:4000/api
# In production: https://your-backend-service.up.railway.app/api
NEXT_PUBLIC_CLOUD_API_URL=https://your-backend-service.up.railway.app/api

# Optional: Request timeout in milliseconds (default: 30000)
NEXT_PUBLIC_API_TIMEOUT=30000

# App Configuration
NEXT_PUBLIC_APP_NAME=POS Monitor Dashboard
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_RTL=true
NEXT_PUBLIC_LOCALE=ar
